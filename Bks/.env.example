# Copy this file to .env and fill in real secret values.
# This file is NOT loaded by the application; it is a reference for developers.

# Server
SERVER_PORT=8080

# Database (MariaDB)
SPRING_DATASOURCE_URL=jdbc:mariadb://localhost:3306/bks?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=kali

# JWT
JWT_SECRET=VotreCleSuperSecreteIciPourJWTTokenQuiDoitEtreTresLongueEtSecurisee2024
JWT_EXPIRATION=86400000

# Mail
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password

# Chatbot API
GROQ_API_KEY=your-groq-api-key
