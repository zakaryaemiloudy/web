				{
					"name": "Health Check",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('API is running', function() {",
									"    pm.response.to.have.status(200);",
									"    var json = pm.response.json();",
									"    pm.expect(json.status).to.eql('UP');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/public/health",
							"host": ["{{baseUrl}}"],
							"path": ["public", "health"]
						},
						"description": "Verifier que l'API fonctionne (AUCUNE AUTH REQUISE)"
					}
				},
